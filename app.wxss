page {
  background: #121212;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.card {
  background: #1e1e1e;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.search-card {
  overflow: visible;
  position: relative;
  z-index: 20;
}

.brand-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-left {
  display: flex;
  align-items: center;  
}

.brand-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #e53935, #c62828);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 20rpx;
}

.brand-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.brand-sub {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.clock-box {
  background: #2a2a2a;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #aaa;
  font-variant-numeric: tabular-nums;
}

.search-label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: 40rpx;
  color: #fff;
  background: transparent;
}

.search-btn {
  background: #f5c518;
  color: #1a1a1a;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 0 36rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  border: none;
}

.search-btn::after {
  border: none;
}

.disclaimer {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 24rpx;
  text-align: center;
}

.up {
  color: #ff4d4f;
}

.down {
  color: #00c853;
}

.tag-safe {
  background: rgba(0, 200, 83, 0.15);
  color: #00c853;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.tag-market {
  background: rgba(33, 150, 243, 0.2);
  color: #64b5f6;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.tag-board {
  background: #2a2a2a;
  color: #999;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #666;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  min-height: 360rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #2a2a2a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #666;
  margin-bottom: 32rpx;
}

.empty-icon.search-icon {
  font-size: 56rpx;
  font-weight: 300;
}

.empty-icon.lhb-icon {
  font-size: 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: center;
}

.empty-sub {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-top: 8rpx;
  text-align: center;
}

.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #888;
  font-size: 28rpx;
}
