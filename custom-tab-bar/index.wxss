.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #141414;
  border-top: 1rpx solid #2a2a2a;
  display: flex;
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding-top: 8rpx;
}

.tab-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 6rpx;
}

.tab-icon-wrap.active-border {
  border: 2rpx solid #f5c518;
}

.tab-icon {
  font-size: 28rpx;
  color: #888;
  font-weight: bold;
}

.tab-item.active .tab-icon {
  color: #f5c518;
}

.search-icon {
  font-size: 32rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #888;
}

.tab-item.active .tab-text {
  color: #f5c518;
}

.tab-line {
  position: absolute;
  bottom: 12rpx;
  width: 40rpx;
  height: 4rpx;
  background: #f5c518;
  border-radius: 2rpx;
}
