.ph {
  color: #555;
  font-size: 32rpx;
}

.lhb-item {
  padding: 28rpx;
}

.lhb-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.lhb-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 12rpx;
}

.lhb-code {
  font-size: 26rpx;
  color: #888;
}

.lhb-date {
  display: block;
  font-size: 28rpx;
  color: #f5c518;
  margin-top: 12rpx;
}

.lhb-turnover {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}

.lhb-reason {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
  line-height: 1.45;
}

.lhb-right {
  text-align: right;
}

.lhb-price {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
}

.lhb-chg {
  display: block;
  font-size: 30rpx;
  margin-top: 8rpx;
}
